# Data — never commit real DOL files or any client-adjacent data
data/*
!data/.gitkeep
!data/employer_rk_index.csv
discovery-front-door/data/*
!discovery-front-door/data/.gitkeep
!discovery-front-door/data/employer_rk_index.csv
rollover-companion/data/*
!rollover-companion/data/.gitkeep
!rollover-companion/data/employer_rk_index.csv
rollover-playbook-engine/data/*
!rollover-playbook-engine/data/.gitkeep

# Secrets — real values go in Streamlit Cloud's Secrets UI, not in the repo
.streamlit/secrets.toml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Large local recordings (keep committed demo videos)
*.mp4
!demo/recordkeeper_exec_demo.mp4
!demo/recordkeeper_demo_90s.mp4

# IDE / OS
.vscode/
.idea/
.DS_Store

# Notebooks (if you do exploration in /notebooks)
.ipynb_checkpoints/
